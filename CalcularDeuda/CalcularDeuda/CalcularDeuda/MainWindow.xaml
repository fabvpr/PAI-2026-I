<Window x:Class="CalcularDeuda.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CalcularDeuda"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Label Content="Cliente" HorizontalAlignment="Left" Margin="131,89,0,0" VerticalAlignment="Top"/>
        <Label Content="Deuda" HorizontalAlignment="Left" Margin="131,133,0,0" VerticalAlignment="Top"/>
        <TextBox x:Name="txt_cliente" HorizontalAlignment="Left" Margin="210,89,0,0" TextWrapping="Wrap" Text="TextBox" VerticalAlignment="Top" Width="120"/>
        <TextBox x:Name="txt_deuda" HorizontalAlignment="Left" Margin="210,133,0,0" TextWrapping="Wrap" Text="TextBox" VerticalAlignment="Top" Width="120"/>
        <Border BorderBrush="Black" BorderThickness="1" Margin="154,189,234,176">
            <Label Content="Beneficios de pago" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-1,-19,0,0"/>
        </Border>
        <CheckBox x:Name="check_descuento" Content="Descuento" HorizontalAlignment="Left" Margin="178,0,0,0" VerticalAlignment="Center"/>
        <CheckBox x:Name="check_bonus" Content="Puntos bonus" HorizontalAlignment="Left" Margin="400,208,0,0" VerticalAlignment="Top"/>
        <TextBox x:Name="txt_descuento" HorizontalAlignment="Left" Margin="176,297,0,0" TextWrapping="Wrap" Text="TextBox" VerticalAlignment="Top" Width="120"/>
        <TextBox x:Name="txt_bonus" HorizontalAlignment="Left" Margin="400,297,0,0" TextWrapping="Wrap" Text="TextBox" VerticalAlignment="Top" Width="120"/>
        <Button x:Name="bt_calcular" Content="Calcular" HorizontalAlignment="Left" Margin="86,338,0,0" VerticalAlignment="Top" Click="bt_calcular_Click"/>
        <Label x:Name="lb_resultado" Content="Total a pagar" HorizontalAlignment="Left" Margin="178,332,0,0" VerticalAlignment="Top" Width="426"/>
        <Label x:Name="lb_descuetno" Content="" HorizontalAlignment="Left" Margin="65,375,0,0" VerticalAlignment="Top" Width="687"/>

    </Grid>
</Window>
