<Window x:Class="Callculo_impuesto.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Callculo_impuesto"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid x:Name="">
        <Label Content="INFORMACIÓN GENERAL" HorizontalAlignment="Center" Margin="0,42,0,0" VerticalAlignment="Top" FontSize="17" Width="800" Foreground="White" Background="#FF474747"/>
        <Label x:Name="lb_personal" Content="Personal" HorizontalAlignment="Left" Margin="66,92,0,0" VerticalAlignment="Top" Height="34" FontSize="17"/>
        <TextBox x:Name="txt_personal" HorizontalAlignment="Left" Margin="159,96,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="120" Height="18" FontSize="17"/>
        <Label x:Name="lb_codigo" Content="Código" HorizontalAlignment="Left" Margin="406,97,0,0" VerticalAlignment="Top" FontSize="17"/>
        <TextBox x:Name="txt_codigo" HorizontalAlignment="Left" Margin="503,101,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="120" FontSize="17"/>
        <CheckBox x:Name="Check_fonavi" Content="Fonavi(8%)" HorizontalAlignment="Left" Margin="49,131,0,0" VerticalAlignment="Top" Height="30" FontSize="17"/>
        <CheckBox x:Name="Check_importe" Content="Imp.Renta (5%)" HorizontalAlignment="Left" Margin="49,166,0,0" VerticalAlignment="Top" Height="26" FontSize="17"/>
        <CheckBox x:Name="Check_afp" Content="A.F.P(12%)" HorizontalAlignment="Left" Margin="49,197,0,0" VerticalAlignment="Top" Height="26" FontSize="17"/>
        <TextBox x:Name="txt_ingresos" HorizontalAlignment="Left" Margin="159,230,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="120" Height="27" FontSize="17"/>
        <Label x:Name="lb_ingresos" Content="Ingresos" HorizontalAlignment="Left" Margin="55,223,0,0" VerticalAlignment="Top" Height="34" FontSize="17"/>
        <Label Content="RESULTADO" HorizontalAlignment="Center" Margin="0,275,0,0" VerticalAlignment="Top" FontSize="17" Width="800" Foreground="White" Background="#FF474747"/>
        <Label x:Name="lb_fonavi" Content="Fonavi:" HorizontalAlignment="Left" Margin="22,326,0,0" VerticalAlignment="Top" Height="37" FontSize="17"/>
        <Label x:Name="lb_impuesto" Content="Imp.Renta:" HorizontalAlignment="Left" Margin="22,356,0,0" VerticalAlignment="Top" Height="31" FontSize="17"/>
        <Label x:Name="lb_afp" Content="A.F.P:" HorizontalAlignment="Left" Margin="28,387,0,0" VerticalAlignment="Top" Height="29" FontSize="17"/>
        <Label x:Name="lb_resultado" Content="Total a pagar:" HorizontalAlignment="Left" Margin="400,347,0,0" VerticalAlignment="Top" FontSize="17"/>
        <Button x:Name="bt_calcular" Content="Calcular" HorizontalAlignment="Left" Margin="503,217,0,0" VerticalAlignment="Top" FontSize="17" Click="bt_calcular_Click"/>

    </Grid>
</Window>
