<Window x:Class="CentroOdontológico.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CentroOdontológico"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid Margin="72,85,448,217">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="9*"/>
                <ColumnDefinition Width="13*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="45*"/>
                <RowDefinition Height="45*"/>
                <RowDefinition Height="45*"/>
            </Grid.RowDefinitions>
            <Label Content="Paciente" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <Label Content="Tratamiento" HorizontalAlignment="Center" Grid.Row="1" VerticalAlignment="Center"/>
            <Label Content="Pieza Dental" HorizontalAlignment="Center" Grid.Row="2" VerticalAlignment="Center"/>
            <TextBox x:Name="txtPaciente" Grid.Column="1" HorizontalAlignment="Center" TextWrapping="Wrap" Text="" VerticalAlignment="Center" Width="120"/>
            <ComboBox x:Name="cbTratamiento" Grid.Column="1" HorizontalAlignment="Center" Grid.Row="1" VerticalAlignment="Center" Width="120">
                <ComboBoxItem Content="Odontológia general"/>
                <ComboBoxItem Content="Endodoncia"/>
                <ComboBoxItem Content="Ortodoncia"/>
                <ComboBoxItem Content="Implante"/>
                <ComboBoxItem Content="Protesis"/>
                <ComboBoxItem Content="Estética Dental"/>
                <ComboBoxItem Content="Periodioncia"/>
            </ComboBox>
            <ComboBox x:Name="cbPieza" Grid.Column="1" HorizontalAlignment="Center" Grid.Row="2" VerticalAlignment="Center" Width="120">
                <ComboBoxItem Content="Incisivos"/>
                <ComboBoxItem Content="Caninos"/>
                <ComboBoxItem Content="Premolares"/>
                <ComboBoxItem Content="Molares"/>
            </ComboBox>
        </Grid>
        <Calendar x:Name="Calendario" HorizontalAlignment="Left" Margin="483,49,0,0" VerticalAlignment="Top"/>
        <Button x:Name="btCronogramar" Content="Cronogramar" HorizontalAlignment="Center" Margin="0,236,0,0" VerticalAlignment="Top" Height="23" Width="96" Click="btCronogramar_Click"/>
        <TextBox x:Name="txtResultado" HorizontalAlignment="Left" Margin="72,283,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="650" Height="106"/>

    </Grid>
</Window>
