<Window x:Class="Registro_de_clientes.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Registro_de_clientes"
        mc:Ignorable="d"
        Title="RegistroClientes" Height="500" Width="850" WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Label Content="Apellidos" HorizontalAlignment="Left" Margin="44,20,0,0" VerticalAlignment="Top" FontWeight="Bold" FontSize="14"/>
        <TextBox x:Name="txtApellido" HorizontalAlignment="Left" Margin="44,50,0,0" VerticalAlignment="Top" Width="320" Height="26" VerticalContentAlignment="Center"/>

        <Label Content="Nombres" HorizontalAlignment="Left" Margin="450,20,0,0" VerticalAlignment="Top" FontWeight="Bold" FontSize="14"/>
        <TextBox x:Name="txtNombre" HorizontalAlignment="Left" Margin="450,50,0,0" VerticalAlignment="Top" Width="340" Height="26" VerticalContentAlignment="Center"/>

        <Label Content="D.N.I." HorizontalAlignment="Left" Margin="44,85,0,0" VerticalAlignment="Top" FontWeight="Bold" FontSize="14"/>
        <TextBox x:Name="txtDNI" HorizontalAlignment="Left" Margin="44,115,0,0" VerticalAlignment="Top" Width="200" Height="26" VerticalContentAlignment="Center"/>

        <Label Content="Dirección" HorizontalAlignment="Left" Margin="330,85,0,0" VerticalAlignment="Top" FontWeight="Bold" FontSize="14"/>
        <TextBox x:Name="txtDireccion" HorizontalAlignment="Left" Margin="330,115,0,0" VerticalAlignment="Top" Width="460" Height="26" VerticalContentAlignment="Center"/>

        <Label Content="Estado Civil" HorizontalAlignment="Left" Margin="44,150,0,0" VerticalAlignment="Top" FontWeight="Bold" FontSize="14"/>
        <ComboBox x:Name="cbEstadoCivil" HorizontalAlignment="Left" Margin="44,180,0,0" VerticalAlignment="Top" Width="200" Height="26" VerticalContentAlignment="Center">
            <ComboBoxItem Content="Soltero(a)"/>
            <ComboBoxItem Content="Casado(a)"/>
        </ComboBox>

        <Button x:Name="btnGrabar" Content="Grabar" HorizontalAlignment="Left" Margin="370,180,0,0" VerticalAlignment="Top" Width="90" Height="28" Background="LightBlue" Click="btnGrabar_Click"/>
        <Button x:Name="btnNuevo" Content="Nuevo" HorizontalAlignment="Left" Margin="480,180,0,0" VerticalAlignment="Top" Width="90" Height="28" Click="btnNuevo_Click"/>
        <Button x:Name="btnEstadistica" Content="Estadística" HorizontalAlignment="Left" Margin="590,180,0,0" VerticalAlignment="Top" Width="90" Height="28" Click="btnEstadistica_Click"/>
        <Button x:Name="btnSalir" Content="Salir" HorizontalAlignment="Left" Margin="700,180,0,0" VerticalAlignment="Top" Width="90" Height="28" Click="btnSalir_Click"/>

        <ListView x:Name="lvClientes" Margin="10,230,10,60">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Apellidos" DisplayMemberBinding="{Binding Apellidos}" Width="180"/>
                    <GridViewColumn Header="Nombres" DisplayMemberBinding="{Binding Nombre}" Width="180"/>
                    <GridViewColumn Header="D.N.I." DisplayMemberBinding="{Binding DNI}" Width="100"/>
                    <GridViewColumn Header="Dirección" DisplayMemberBinding="{Binding Direccion}" Width="220"/>
                    <GridViewColumn Header="Estado Civil" DisplayMemberBinding="{Binding EstadoCivil}" Width="110"/>
                </GridView>
            </ListView.View>
        </ListView>

        <Label Content="Solteros:" HorizontalAlignment="Left" Margin="150,0,0,15" VerticalAlignment="Bottom" FontWeight="Bold" FontSize="14"/>
        <TextBox x:Name="txtContadorSolteros" HorizontalAlignment="Left" Margin="220,0,0,15" VerticalAlignment="Bottom" Width="80" Height="26" IsReadOnly="True" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>

        <Label Content="Casados:" HorizontalAlignment="Left" Margin="480,0,0,15" VerticalAlignment="Bottom" FontWeight="Bold" FontSize="14"/>
        <TextBox x:Name="txtContadorCasados" HorizontalAlignment="Left" Margin="550,0,0,15" VerticalAlignment="Bottom" Width="80" Height="26" IsReadOnly="True" VerticalContentAlignment="Center" HorizontalContentAlignment="Center"/>
    </Grid>
</Window>