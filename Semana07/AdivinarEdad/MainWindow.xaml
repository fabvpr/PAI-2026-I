<Window x:Class="AdivinarEdad.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AdivinarEdad"
        mc:Ignorable="d"
        Title="AdivinarEdad" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="63*"/>
            <RowDefinition Height="63*"/>
            <RowDefinition Height="63*"/>
            <RowDefinition Height="63*"/>
            <RowDefinition Height="63*"/>
            <RowDefinition Height="63*"/>
        </Grid.RowDefinitions>
        <Label Content="Indicale al computador un intervalo de edades" HorizontalAlignment="Center" VerticalAlignment="Center" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" FontWeight="Bold" Height="25" Width="280"/>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160*"/>
                <ColumnDefinition Width="120*"/>
                <ColumnDefinition Width="80*"/>
                <ColumnDefinition Width="120*"/>
                <ColumnDefinition Width="160*"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="txtPrimerIntervalo" Grid.Column="1" HorizontalAlignment="Center" TextWrapping="Wrap" Text="" VerticalAlignment="Center" Width="120" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" FontSize="15" Height="43"/>
            <TextBox x:Name="txtSegundoIntervalo" Grid.Column="3" HorizontalAlignment="Center" TextWrapping="Wrap" Text="" VerticalAlignment="Center" Width="120" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" FontSize="15" Height="43" Margin="10,0,0,0"/>
        </Grid>
        <Button x:Name="btIntento" Content="Intentarlo" HorizontalAlignment="Center" Grid.Row="2" VerticalAlignment="Center" Padding="15,5,15,5" FontSize="15" Click="btIntento_Click"/>
        <Label Content="La computador piensa que tu edad es:" HorizontalAlignment="Center" Grid.Row="3" VerticalAlignment="Center" FontWeight="Bold"/>
        <TextBox x:Name="txtResultado" HorizontalAlignment="Center" Grid.Row="4" TextWrapping="Wrap" Text="" VerticalAlignment="Center" Width="120" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Padding="5,5,5,5" Height="52"/>
        <Grid Grid.Row="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160*"/>
                <ColumnDefinition Width="120*"/>
                <ColumnDefinition Width="80*"/>
                <ColumnDefinition Width="120*"/>
                <ColumnDefinition Width="160*"/>
            </Grid.ColumnDefinitions>
            <Button x:Name="btCorrecto" Grid.Column="1" Content="Correcto" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="15,5,15,5" Click="btCorrecto_Click"/>
            <Button x:Name="btIncorrecto" Grid.Column="3" Content="Incorrecto" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="15,5,15,12" Click="btIncorrecto_Click"/>
        </Grid>

    </Grid>
</Window>
