<Window x:Class="Tragamonedas.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Tragamonedas"
        mc:Ignorable="d"
        Title="Tragamonedas" Height="450" Width="800" Loaded="Window_Loaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40*"/>
            <RowDefinition Height="85*"/>
            <RowDefinition Height="60*"/>
            <RowDefinition Height="50*"/>
            <RowDefinition Height="65*"/>
            <RowDefinition Height="40*"/>
        </Grid.RowDefinitions>
        <Label x:Name="lbReloj" Content="00:00:00" HorizontalAlignment="Center" Grid.Row="1" VerticalAlignment="Center" FontWeight="Bold" FontSize="50" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Foreground="Black" Background="#FFB3BE3C" Height="109" Width="225"/>
        <Button x:Name="btIniciarJuego" Content="Iniciar Juego" HorizontalAlignment="Center" Grid.Row="2" VerticalAlignment="Center" FontSize="15" FontWeight="Bold" Padding="15,5,15,5" Click="btIniciarJuego_Click"/>
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="35*"/>
                <ColumnDefinition Width="250*"/>
                <ColumnDefinition Width="250*"/>
                <ColumnDefinition Width="250*"/>
                <ColumnDefinition Width="35*"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="txtJugada1" Grid.Column="1" HorizontalAlignment="Center" TextWrapping="Wrap" Text="" VerticalAlignment="Center" Width="79" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Padding="5,5,16,5" FontSize="15" FontWeight="Bold" Height="51" IsReadOnly="True"/>
            <TextBox x:Name="txtJugada2" Grid.Column="2" HorizontalAlignment="Center" TextWrapping="Wrap" Text="" VerticalAlignment="Center" Width="79" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Padding="5,5,5,5" FontSize="15" FontWeight="Bold" Height="51" IsReadOnly="True"/>
            <TextBox x:Name="txtJugada3" Grid.Column="3" HorizontalAlignment="Center" TextWrapping="Wrap" Text="" VerticalAlignment="Center" Width="79" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Padding="5,5,5,5" FontSize="15" FontWeight="Bold" Height="51" IsReadOnly="True"/>
        </Grid>
        <Label x:Name="lbResultado" Content="" HorizontalAlignment="Center" Grid.Row="4" VerticalAlignment="Center" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Width="412" FontSize="20" FontWeight="Bold" Visibility="Hidden"/>

    </Grid>
</Window>
