<Window x:Class="OrdenarCadena.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OrdenarCadena"
        mc:Ignorable="d"
        Title="MainWindow" Height="487" Width="800">
    <Grid Margin="37,37,37,50">
        <Grid.RowDefinitions>
            <RowDefinition Height="87*"/>
            <RowDefinition Height="Auto" MinHeight="53
                           "/>
            <RowDefinition Height="201*"/>
            <RowDefinition Height="53*"/>
        </Grid.RowDefinitions>
        <TextBox x:Name="txtNombres" HorizontalAlignment="Center" TextWrapping="Wrap" Text="Liliana Angelina Letica Amanda Patricia Roxana Luana Laura Kiara Kimberly Synthia Cintia Cecilia Ana Lina Thalia Teresa Pierina" VerticalAlignment="Center" Width="706" Height="75"/>
        <Grid Margin="0,79,0,0" Grid.RowSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="187*"/>
                <ColumnDefinition Width="540*"/>
            </Grid.ColumnDefinitions>
            <Button x:Name="btListar" Content="Lista>>" HorizontalAlignment="Center" VerticalAlignment="Center" Width="82" Height="33" Click="btListar_Click"/>
        </Grid>
        <Grid Grid.Row="1" Margin="0,53,0,0" Grid.RowSpan="2">
            <ListBox x:Name="lbNombres" d:ItemsSource="{d:SampleData ItemCount=5}" Margin="0,0,533,0"/>
            <Grid Margin="264,0,264,0" Height="114" VerticalAlignment="Center">
                <Grid.RowDefinitions>
                    <RowDefinition Height="38*"/>
                    <RowDefinition Height="39*"/>
                    <RowDefinition Height="37*"/>
                </Grid.RowDefinitions>
                <Label Content="Lista" HorizontalAlignment="Center" VerticalAlignment="Center" Width="36" Height="26"/>
                <TextBox x:Name="txtLetraNombreFiltrado" HorizontalAlignment="Center" Grid.Row="1" TextWrapping="Wrap" Text="" VerticalAlignment="Center" Width="120" Height="38"/>
                <Button x:Name="btPasar" Content="Pasar" HorizontalAlignment="Center" Grid.Row="2" VerticalAlignment="Center" Width="94" Height="17" Click="btPasar_Click"/>
            </Grid>
            <ListBox x:Name="lbNombresFiltrados" d:ItemsSource="{d:SampleData ItemCount=5}" Margin="533,0,0,0"/>
        </Grid>
        <Grid Grid.Row="3" Height="42" VerticalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="193*"/>
                <ColumnDefinition Width="97*"/>
                <ColumnDefinition Width="155*"/>
                <ColumnDefinition Width="97*"/>
                <ColumnDefinition Width="191*"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="txtTotalNombre" HorizontalAlignment="Center" TextWrapping="Wrap" Text="" VerticalAlignment="Center" Width="96" Grid.Column="1" Height="32"/>
            <TextBox x:Name="txtTotalNombreFiltrados" Grid.Column="3" HorizontalAlignment="Center" TextWrapping="Wrap" Text="" VerticalAlignment="Center" Width="96" Height="32"/>
        </Grid>

    </Grid>
</Window>
