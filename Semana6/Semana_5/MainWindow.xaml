<Window x:Class="Semana_5.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Semana_5"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="55*"/>
            <RowDefinition Height="46*"/>
            <RowDefinition Height="43*"/>
            <RowDefinition Height="80*"/>
            <RowDefinition Height="210*"/>
        </Grid.RowDefinitions>
        <Label Content="Cliente" HorizontalAlignment="Left" Margin="85,5,0,0" Grid.Row="1" VerticalAlignment="Top" Width="55" Height="26"/>
        <TextBox x:Name="txtCliente" HorizontalAlignment="Left" Margin="145,5,0,0" Grid.Row="1" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="120" Height="26"/>
        <Label Content="Fch. Venc:" HorizontalAlignment="Left" Margin="74,7,0,0" Grid.Row="2" VerticalAlignment="Top" Height="26" Width="66"/>
        <Label Content="Monto" HorizontalAlignment="Left" Margin="460,0,0,0" Grid.Row="1" VerticalAlignment="Center" Height="26" Width="46"/>
        <TextBox x:Name="txtMonto" HorizontalAlignment="Left" Margin="525,0,0,0" Grid.Row="1" TextWrapping="Wrap" Text="" VerticalAlignment="Center" Width="120" Height="26"/>
        <Label Content="NuevaFch. Pago:" HorizontalAlignment="Left" Margin="420,0,0,0" Grid.Row="2" VerticalAlignment="Center" Height="26" Width="96"/>
        <Button x:Name="btCalcular" Content="Calcular" HorizontalAlignment="Left" Margin="145,30,0,0" Grid.Row="3" VerticalAlignment="Top" Height="30" Width="78" Click="btCalcular_Click"/>
        <Button x:Name="btNuevo" Content="Nuevo" HorizontalAlignment="Center" Margin="0,30,0,0" Grid.Row="3" VerticalAlignment="Top" Height="30" Width="90" Click="btNuevo_Click"/>
        <Button x:Name="btFinalizar" Content="Finalizar" HorizontalAlignment="Left" Margin="559,30,0,0" Grid.Row="3" VerticalAlignment="Top" Height="30" Width="86" Click="btFinalizar_Click"/>
        <DatePicker x:Name="dpFchVenc" HorizontalAlignment="Left" Margin="145,0,0,0" Grid.Row="2" VerticalAlignment="Center"/>
        <DatePicker x:Name="dpFchPago" HorizontalAlignment="Left" Margin="525,0,0,0" Grid.Row="2" VerticalAlignment="Center"/>
        <Grid Grid.Row="4" Margin="10,0,15,115" Height="85" VerticalAlignment="Bottom">
            <Grid.RowDefinitions>
                <RowDefinition Height="10*"/>
                <RowDefinition Height="10*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="7*"/>
                <ColumnDefinition Width="21*"/>
                <ColumnDefinition Width="48*"/>
                <ColumnDefinition Width="9*"/>
                <ColumnDefinition Width="21*"/>
                <ColumnDefinition Width="48*"/>
                <ColumnDefinition Width="7*"/>
            </Grid.ColumnDefinitions>
            <Label Grid.Column="1" Content="Días de mora:" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <TextBox x:Name="txtDíasMora" Grid.Column="2" HorizontalAlignment="Center" TextWrapping="Wrap" Text="" VerticalAlignment="Center" Width="190" Background="#FFDD6C6C"/>
            <Label Grid.Column="1" Content="Mora en %" HorizontalAlignment="Center" Grid.Row="1" VerticalAlignment="Center"/>
            <TextBox x:Name="txtMoraPorce" Grid.Column="2" HorizontalAlignment="Center" Grid.Row="1" TextWrapping="Wrap" Text="" VerticalAlignment="Center" Width="190" Background="#FFDD6C6C"/>
            <Label Grid.Column="4" Content="Mora en S/:" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <TextBox x:Name="txtMontoPagar" Grid.Column="5" HorizontalAlignment="Center" TextWrapping="Wrap" Text="" VerticalAlignment="Center" Width="188" Grid.Row="1" Background="#FFDD6C6C"/>
            <TextBox x:Name="txtMorasol" Grid.Column="5" HorizontalAlignment="Center" TextWrapping="Wrap" Text="" VerticalAlignment="Center" Width="188" Background="#FFDD6C6C"/>
            <Label Grid.Column="4" Content="Monto pagar:" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,4,0,0" Grid.Row="1"/>
        </Grid>

    </Grid>
</Window>
